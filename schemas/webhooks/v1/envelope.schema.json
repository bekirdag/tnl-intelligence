{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theneuralledger.com/schemas/webhooks/v1/envelope.schema.json",
  "title": "TNL Webhook Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "schemaVersion",
    "occurredAt",
    "publishedAt",
    "tenantId",
    "resource",
    "data",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^evt_[A-Za-z0-9_-]{12,80}$" },
    "type": {
      "type": "string",
      "enum": [
        "intelligence.published",
        "intelligence.updated",
        "intelligence.retracted",
        "intelligence.impact_changed",
        "digest.weekly_published",
        "subscription.test"
      ]
    },
    "schemaVersion": { "const": "1.0" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "minLength": 1, "maxLength": 120 },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "url"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "revision": { "type": "integer", "minimum": 1 },
        "url": { "type": "string", "format": "uri", "maxLength": 2048 }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "categories",
        "geographies",
        "entities",
        "assets",
        "impactPaths",
        "provenance"
      ],
      "properties": {
        "summary": { "type": "string", "maxLength": 2000 },
        "categories": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 120 }
        },
        "geographies": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 120 }
        },
        "entities": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "maxLength": 160 }
        },
        "assets": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "maxLength": 80 }
        },
        "impactPaths": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 160 }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$" },
        "provenance": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "format": "uri", "maxLength": 2048 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "traceId"],
      "properties": {
        "producer": { "const": "tnl" },
        "traceId": { "type": "string", "minLength": 8, "maxLength": 120 }
      }
    }
  }
}
