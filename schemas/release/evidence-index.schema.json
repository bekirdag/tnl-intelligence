{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theneuralledger.com/schemas/release/evidence-index-v1.json",
  "title": "TNL Intelligence qualification evidence index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "candidateId",
    "generatedAt",
    "lanes",
    "scenarios",
    "records",
    "decision"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "candidateId": { "type": "string", "pattern": "^tnl-rc-[a-f0-9]{16}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "lanes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "state", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "state": { "enum": ["pass", "fail", "pending-owner"] },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "state", "durationMs", "commands", "candidateId"],
        "properties": {
          "id": { "type": "string", "pattern": "^scenario-[1-6]$" },
          "name": { "type": "string", "minLength": 1 },
          "state": { "enum": ["pass", "fail"] },
          "durationMs": { "type": "integer", "minimum": 0 },
          "commands": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "candidateId": { "type": "string", "pattern": "^tnl-rc-[a-f0-9]{16}$" }
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["technical", "publication", "ownerApprovalRequired"],
      "properties": {
        "technical": { "enum": ["go", "no-go"] },
        "publication": { "const": "no-go-pending-owner" },
        "ownerApprovalRequired": { "const": true }
      }
    }
  }
}
