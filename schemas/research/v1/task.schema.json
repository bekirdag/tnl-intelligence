{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theneuralledger.com/schemas/research/v1/task.schema.json",
  "title": "TNL Research Task v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "taskType",
    "question",
    "asOf",
    "timeWindow",
    "depth",
    "sourcePolicy",
    "budget",
    "outputFormat",
    "locale"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "taskId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "taskType": {
      "enum": [
        "what_changed",
        "source_comparison",
        "event_validation",
        "asset_entity_exposure",
        "geopolitical_operational_risk",
        "weekly_consequential"
      ]
    },
    "question": { "type": "string", "minLength": 3, "maxLength": 8000 },
    "asOf": { "type": "string", "format": "date-time" },
    "timeWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      }
    },
    "selectedStoryIds": { "type": "array", "maxItems": 100, "items": { "type": "string" } },
    "entities": { "type": "array", "maxItems": 100, "items": { "type": "string" } },
    "geographies": { "type": "array", "maxItems": 100, "items": { "type": "string" } },
    "categories": { "type": "array", "maxItems": 100, "items": { "type": "string" } },
    "assets": { "type": "array", "maxItems": 100, "items": { "type": "string" } },
    "scenarios": { "type": "array", "maxItems": 25, "items": { "type": "string" } },
    "depth": { "enum": ["brief", "standard", "deep"] },
    "sourcePolicy": { "$ref": "#/$defs/sourcePolicy" },
    "budget": { "$ref": "#/$defs/budget" },
    "outputFormat": { "enum": ["json", "markdown"] },
    "locale": { "type": "string", "minLength": 2, "maxLength": 35 }
  },
  "$defs": {
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxToolCalls",
        "maxDurationMs",
        "maxInputTokens",
        "maxOutputTokens",
        "maxSources",
        "maxCostUsd"
      ],
      "properties": {
        "maxToolCalls": { "type": "integer", "minimum": 0 },
        "maxDurationMs": { "type": "integer", "minimum": 0 },
        "maxInputTokens": { "type": "integer", "minimum": 0 },
        "maxOutputTokens": { "type": "integer", "minimum": 0 },
        "maxSources": { "type": "integer", "minimum": 0 },
        "maxCostUsd": { "type": "number", "minimum": 0 }
      }
    },
    "sourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "requirePrimary", "minimumIndependentSources", "freshnessMs"],
      "properties": {
        "version": { "type": "string" },
        "requirePrimary": { "type": "boolean" },
        "minimumIndependentSources": { "type": "integer", "minimum": 1 },
        "freshnessMs": { "type": "integer", "minimum": 0 },
        "allowedDomains": { "type": "array", "items": { "type": "string" } },
        "deniedDomains": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
