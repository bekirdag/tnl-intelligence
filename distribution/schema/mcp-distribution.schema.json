{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bekirdag/tnl-intelligence/distribution/schema/mcp-distribution.schema.json",
  "title": "TNL MCP distribution manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatorVersion",
    "product",
    "runtime",
    "transports",
    "clients",
    "platforms",
    "links",
    "artifacts",
    "limits"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0" },
    "generatorVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "displayName",
        "description",
        "version",
        "license",
        "package",
        "mcpName"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "license": { "type": "string", "minLength": 1 },
        "package": { "type": "string", "pattern": "^@theneuralledger/" },
        "mcpName": { "type": "string", "pattern": "^com\\.theneuralledger/" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "mcpProtocol", "packageEntry", "binary"],
      "properties": {
        "node": { "type": "string", "minLength": 1 },
        "mcpProtocol": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "packageEntry": { "$ref": "#/definitions/relativePath" },
        "binary": { "type": "string", "minLength": 1 }
      }
    },
    "transports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local", "remote"],
      "properties": {
        "local": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "command", "requiredEnvironment", "optionalEnvironment"],
          "properties": {
            "type": { "const": "stdio" },
            "command": { "type": "string", "minLength": 1 },
            "requiredEnvironment": {
              "type": "array",
              "items": { "$ref": "#/definitions/environment" }
            },
            "optionalEnvironment": {
              "type": "array",
              "items": { "$ref": "#/definitions/environment" }
            }
          }
        },
        "remote": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "url", "oauthMetadataUrl", "scopes"],
          "properties": {
            "type": { "const": "http" },
            "url": { "type": "string", "format": "uri", "pattern": "^https://" },
            "oauthMetadataUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
            "scopes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "clients": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled", "versionPolicy"],
        "properties": {
          "enabled": { "type": "boolean" },
          "versionPolicy": { "type": "string", "minLength": 1 }
        }
      }
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operatingSystems", "architectures", "containerPlatforms"],
      "properties": {
        "operatingSystems": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["darwin", "linux", "win32"] }
        },
        "architectures": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["x64", "arm64"] }
        },
        "containerPlatforms": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["linux/amd64", "linux/arm64"] }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homepage", "documentation", "privacy", "support", "changelog", "source"],
      "properties": {
        "homepage": { "$ref": "#/definitions/httpsUrl" },
        "documentation": { "$ref": "#/definitions/httpsUrl" },
        "privacy": { "$ref": "#/definitions/httpsUrl" },
        "support": { "$ref": "#/definitions/httpsUrl" },
        "changelog": { "$ref": "#/definitions/httpsUrl" },
        "source": { "$ref": "#/definitions/httpsUrl" }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "host"],
        "properties": {
          "path": { "$ref": "#/definitions/relativePath" },
          "kind": { "type": "string", "minLength": 1 },
          "host": { "type": "string", "minLength": 1 }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundleBytes", "imageBytes"],
      "properties": {
        "bundleBytes": { "type": "integer", "minimum": 1 },
        "imageBytes": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "definitions": {
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\\\).+$"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "secret", "required"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
        "description": { "type": "string", "minLength": 1 },
        "secret": { "type": "boolean" },
        "required": { "type": "boolean" },
        "default": { "type": "string" }
      }
    }
  }
}
