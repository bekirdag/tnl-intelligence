{
  "name": "n8n-nodes-tnl-intelligence",
  "version": "0.1.0",
  "description": "TNL Intelligence actions and signed instant triggers for n8n.",
  "license": "MIT",
  "homepage": "https://theneuralledger.com",
  "keywords": [
    "n8n-community-node-package",
    "news",
    "intelligence",
    "research"
  ],
  "author": {
    "name": "The Neural Ledger",
    "email": "bekirdag@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bekirdag/tnl-intelligence.git",
    "directory": "integrations/n8n"
  },
  "scripts": {
    "build": "n8n-node build",
    "lint": "n8n-node lint",
    "test": "node --test test/*.test.cjs",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": ["dist", "README.md"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": ["dist/credentials/TnlApi.credentials.js"],
    "nodes": [
      "dist/nodes/TnlIntelligence/TnlIntelligence.node.js",
      "dist/nodes/TnlTrigger/TnlTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "0.39.3",
    "eslint": "9.39.4",
    "n8n-workflow": "2.30.2",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  },
  "peerDependencies": { "n8n-workflow": "*" },
  "engines": { "node": ">=22" }
}
