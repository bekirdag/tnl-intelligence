{
  "name": "@theneuralledger/research",
  "version": "0.1.0",
  "description": "Evidence-first TNL research skills, orchestration, and application.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.10"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "tnl-research": "./dist/service-bin.js"
  },
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bekirdag/tnl-intelligence.git",
    "directory": "packages/research"
  },
  "scripts": {
    "clean": "rm -rf dist .tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "research",
    "news",
    "intelligence",
    "citations",
    "codali"
  ]
}
