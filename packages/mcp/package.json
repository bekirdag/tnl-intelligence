{
  "name": "@theneuralledger/mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for The Neural Ledger intelligence API.",
  "homepage": "https://github.com/bekirdag/tnl-intelligence#readme",
  "bugs": {
    "url": "https://github.com/bekirdag/tnl-intelligence/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tnl-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "mcpName": "com.theneuralledger/intelligence",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bekirdag/tnl-intelligence.git",
    "directory": "packages/mcp"
  },
  "scripts": {
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@theneuralledger/sdk": "0.1.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "news",
    "intelligence",
    "trading"
  ]
}
