{
  "name": "@theneuralledger/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted OAuth and policy gateway for The Neural Ledger MCP service.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tnl-mcp-gateway": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist .tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@theneuralledger/mcp": "0.1.0",
    "@theneuralledger/research": "0.1.0",
    "@theneuralledger/sdk": "0.1.0"
  }
}
