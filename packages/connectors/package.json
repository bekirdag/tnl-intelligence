{
  "name": "@theneuralledger/connectors",
  "version": "0.1.0",
  "description": "Host-neutral actions, signed triggers, and lifecycle contracts for TNL automation connectors.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.10"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bekirdag/tnl-intelligence.git",
    "directory": "packages/connectors"
  },
  "scripts": {
    "clean": "rm -rf dist .tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@theneuralledger/adapters": "0.1.0",
    "@theneuralledger/events": "0.1.0",
    "@theneuralledger/research": "0.1.0",
    "@theneuralledger/sdk": "0.1.0"
  },
  "keywords": [
    "n8n",
    "pipedream",
    "zapier",
    "webhooks",
    "automation",
    "news"
  ]
}
