{
  "name": "tnl-intelligence-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Developer tools for The Neural Ledger intelligence API.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "integrations/n8n",
    "integrations/pipedream",
    "integrations/zapier"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build --workspace @theneuralledger/sdk && npm run build --workspace @theneuralledger/events && npm run build --workspace @theneuralledger/research && npm run build --workspace @theneuralledger/adapters && npm run build --workspace @theneuralledger/connectors && npm run build --workspace @theneuralledger/mcp && npm run build --workspace @theneuralledger/artifacts && npm run build --workspace @theneuralledger/gateway && npm run build --workspace @theneuralledger/onboarding && npm run build --workspace @theneuralledger/cli",
    "typecheck": "npm run build && npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node --test test/integration/*.test.mjs",
    "test:harness": "node scripts/run-integration-harness.mjs",
    "test:harness:no-container": "node scripts/run-integration-harness.mjs --skip-container",
    "test:onboarding": "node scripts/run-onboarding-qualification.mjs",
    "test:onboarding:browser": "npm run build --workspace @theneuralledger/onboarding && node test/browser/onboarding.browser.mjs",
    "test:webhooks": "node scripts/run-webhook-qualification.mjs",
    "test:webhooks:security": "tsx --test packages/events/test/security.test.ts packages/events/test/endpoint-subscriptions.test.ts",
    "test:webhooks:load": "tsx --test packages/events/test/load.test.ts",
    "test:research": "node scripts/run-research-qualification.mjs",
    "test:research:browser": "npm run build --workspace @theneuralledger/research && node test/browser/research.browser.mjs",
    "test:research:security": "tsx --test packages/research/test/security.test.ts packages/research/test/server.test.ts",
    "test:adapters:contracts": "npm run build --workspace @theneuralledger/research && npm run test --workspace @theneuralledger/adapters",
    "test:distribution": "node scripts/run-distribution-qualification.mjs && bash scripts/run-distribution-container-qualification.sh",
    "test:distribution:no-container": "node scripts/run-distribution-qualification.mjs",
    "test:python": "cd python/tnl_intelligence && python3 -m pytest",
    "lint:python": "cd python/tnl_intelligence && python3 -m ruff check . && python3 -m ruff format --check . && python3 -m mypy src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run openapi:check && npm run onboarding:check && npm run webhooks:check && npm run research:check && npm run distribution:check && npm run adapters:check && npm run connectors:check && npm run quant:check && npm run format:check && npm run typecheck && npm test && npm run build",
    "openapi:sync": "node scripts/openapi.mjs sync",
    "openapi:generate": "node scripts/openapi.mjs generate",
    "openapi:check": "node scripts/openapi.mjs check",
    "pack:check": "node scripts/check-package-tarballs.mjs",
    "onboarding:generate": "node scripts/onboarding-assets.mjs",
    "onboarding:check": "node scripts/onboarding-assets.mjs --check",
    "webhooks:generate": "node scripts/webhook-assets.mjs",
    "webhooks:check": "node scripts/webhook-assets.mjs --check",
    "research:generate": "node scripts/research-assets.mjs",
    "research:check": "node scripts/research-assets.mjs --check",
    "distribution:prerequisites": "npm run build --workspace @theneuralledger/sdk && npm run build --workspace @theneuralledger/research && npm run build --workspace @theneuralledger/mcp && npm run build --workspace @theneuralledger/artifacts",
    "distribution:generate": "npm run distribution:prerequisites && node scripts/distribution-assets.mjs",
    "distribution:check": "npm run distribution:prerequisites && node scripts/distribution-assets.mjs --check",
    "distribution:pack": "npm run distribution:generate && node scripts/pack-distribution.mjs",
    "distribution:inspect": "unzip -t .artifacts/tool-06/tnl-intelligence-0.1.0.mcpb && node -e \"JSON.parse(require('fs').readFileSync('.artifacts/tool-06/provenance.json'))\"",
    "distribution:doctor": "npm run build --workspace @theneuralledger/artifacts && node packages/artifacts/dist/doctor-bin.js",
    "adapters:generate": "npm run build --workspace @theneuralledger/research && npm run build --workspace @theneuralledger/adapters && node scripts/adapter-assets.mjs",
    "adapters:check": "npm run build --workspace @theneuralledger/research && npm run build --workspace @theneuralledger/adapters && node scripts/adapter-assets.mjs --check",
    "test:adapter:cursor": "node --test test/adapters/cursor.test.mjs",
    "test:adapter:openai": "node --test test/adapters/openai.test.mjs",
    "test:adapters:security": "node --test test/adapters/security.test.mjs",
    "test:adapters": "node scripts/run-adapter-qualification.mjs",
    "adapters:pack:local": "npm run adapters:generate && node scripts/pack-adapters.mjs",
    "adapters:review-evidence": "node scripts/run-adapter-qualification.mjs",
    "test:connectors:core": "npm run build --workspace @theneuralledger/sdk && npm run build --workspace @theneuralledger/events && npm run build --workspace @theneuralledger/research && npm run build --workspace @theneuralledger/adapters && npm run test --workspace @theneuralledger/connectors",
    "test:connector:n8n": "node --test test/connectors/n8n.test.mjs",
    "test:connector:pipedream": "node --test test/connectors/pipedream.test.mjs",
    "test:connector:zapier": "node --test test/connectors/zapier.test.mjs",
    "test:connectors:parity": "node --test test/connectors/parity.test.mjs",
    "connectors:prerequisites": "npm run build --workspace @theneuralledger/sdk && npm run build --workspace @theneuralledger/events && npm run build --workspace @theneuralledger/research && npm run build --workspace @theneuralledger/adapters && npm run build --workspace @theneuralledger/connectors",
    "connectors:generate": "npm run connectors:prerequisites && node scripts/connector-assets.mjs",
    "connectors:check": "npm run connectors:prerequisites && node scripts/connector-assets.mjs --check",
    "connectors:pack:local": "npm run connectors:generate && node scripts/pack-connectors.mjs",
    "test:connectors": "node scripts/run-connector-qualification.mjs",
    "quant:generate": "cd python/tnl_intelligence && PYTHONPATH=src ../../.venv/bin/python -m tnl_intelligence.quant.asset_builder --output src/tnl_intelligence/quant/example_assets",
    "quant:check": "cd python/tnl_intelligence && PYTHONPATH=src ../../.venv/bin/python -m tnl_intelligence.quant.asset_builder --output src/tnl_intelligence/quant/example_assets --check",
    "test:quant": "node scripts/run-quant-qualification.mjs",
    "artifacts:release-candidate": "node scripts/release-candidate-assets.mjs",
    "artifacts:prepare": "node scripts/prepare-release-artifacts.mjs",
    "qualify:contracts": "node scripts/run-release-qualification.mjs --lane=contracts",
    "qualify:e2e": "node scripts/run-release-qualification.mjs --lane=e2e",
    "qualify:security": "node scripts/run-release-qualification.mjs --lane=security",
    "qualify:privacy": "node scripts/run-release-qualification.mjs --lane=privacy",
    "qualify:reliability": "node scripts/run-release-qualification.mjs --lane=reliability",
    "qualify:performance": "node scripts/run-release-qualification.mjs --lane=performance",
    "qualify:accessibility": "node scripts/run-release-qualification.mjs --lane=accessibility",
    "qualify:docs": "node scripts/run-release-qualification.mjs --lane=docs",
    "qualify:operations": "node scripts/run-release-qualification.mjs --lane=operations",
    "qualify:release": "node scripts/run-release-qualification.mjs --lane=release"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "form-data": "4.0.6"
  }
}
